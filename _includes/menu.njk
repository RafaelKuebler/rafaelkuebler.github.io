{% for entry in entries %}
    {% if entry.post_list %}
        {% set posts = collections[entry.post_list] %}
        {% if posts %}
            {% set currentYear = "" %}
            {% for post in posts | reverse %}
                {% set postYear = post.date | date("yyyy") %}
                {% if postYear != currentYear %}
                    {% if currentYear != "" %}</ul>{% endif %}
                    <h3 class="year-header">{{ postYear }}</h3>
                    <ul class="year-posts">
                    {% set currentYear = postYear %}
                {% endif %}
                <li class="post-list-item">
                    <time datetime="{{ post.date }}" class="post-date">{{ post.date | date }}</time>
                    <a href="{{ post.url | url }}">{{ post.data.title }}</a>
                </li>
            {% endfor %}
            {% if currentYear != "" %}</ul>{% endif %}
        {% endif %}
    {% endif %}
{% endfor %}