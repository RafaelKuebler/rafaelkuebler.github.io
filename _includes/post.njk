---
layout: base.njk
---
<article>
  <p class="post-meta">
    <time datetime="{{ page.date }}">{{ page.date | date }}</time>
    &bull; About {{ content | readingTime }} reading time
  </p>
  <h1>{{ title }}</h1>
  {{ content | safe  }}
  <p class="project-back">
    <a href="/">← Home</a>
  </p>
</article>
<button id="scrollToTop" class="scroll-to-top" aria-label="Scroll to top">↑</button>